# Runtime
ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://hrms_user:hrms_pass@localhost:5432/hrms_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (RS256) - generate with: python scripts/generate_rsa_keys.py
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ACTIVATION_TOKEN_EXPIRE_HOURS=48

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=hrms-documents
AWS_S3_REGION=ap-south-1

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@hrms.company.com
EMAIL_FROM_NAME=HRMS Platform

# Rate Limiting
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Employee Code
EMPLOYEE_CODE_PREFIX=FIN
EMPLOYEE_CODE_PADDING=3
